<div class="row justify-content-center my-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow rounded-3">
            <div class="card-body p-5">

                <div class="text-center mb-4">
                    <div
                        class="d-inline-flex align-items-center justify-content-center bg-light text-primary rounded-circle p-3 mb-3 fs-3 border">
                        <i class="bi bi-box-arrow-in-right text-primary"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-1">Selamat Datang</h2>
                    <p class="text-secondary small">Masuk ke akun Lifepedia Anda untuk menjelajahi tutorial menarik.</p>
                </div>

                {{#if pesanError}}
                <div class="alert alert-danger rounded-3 border-0 shadow-sm" role="alert">
                    <div class="d-flex align-items-center gap-2 mb-2 fw-semibold">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>Gagal Masuk:</span>
                    </div>
                    <ul class="mb-0 ps-4 small">
                        {{#each pesanError}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}

                {{#if pesanSukses}}
                <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm mb-4"
                    role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <ul class="mb-0 ps-3 small">
                        {{#each pesanSukses}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}

                <form method="POST" action="/auth/login">
                    <div class="mb-3">
                        <label for="email" class="form-label fw-semibold text-secondary small">Alamat Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control bg-light border-start-0 ps-0" id="email"
                                name="email" placeholder="nama@lfpedia.com" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label for="password"
                                class="form-label fw-semibold text-secondary small mb-0">Password</label>
                            <a href="/auth/forgot-password" class="text-decoration-none small">Lupa Password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-lock"></i></span>
                            <input type="password" class="form-control bg-light border-start-0 ps-0" id="password"
                                name="password" placeholder="••••••••" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold shadow-sm mb-3">
                        Login
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="text-secondary small mb-0">Belum punya akun? <a href="/auth/register"
                            class="text-decoration-none fw-semibold">Daftar Sekarang</a></p>
                </div>

            </div>
        </div>
    </div>
</div>