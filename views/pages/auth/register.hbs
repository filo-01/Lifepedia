<div class="row justify-content-center my-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow rounded-3">
            <div class="card-body p-5">

                <div class="text-center mb-4">
                    <div
                        class="d-inline-flex align-items-center justify-content-center bg-light text-primary rounded-circle p-3 mb-3 fs-3 border">
                        <i class="bi bi-person-plus-fill text-primary"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-1">Daftar Akun</h2>
                    <p class="text-secondary small">Bergabunglah dengan komunitas Lifepedia dan bagikan lifehack
                        terbaikmu.</p>
                </div>

                {{#if pesanError}}
                <div class="alert alert-danger rounded-3 border-0 shadow-sm" role="alert">
                    <div class="d-flex align-items-center gap-2 mb-2 fw-semibold">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>Gagal Mendaftar:</span>
                    </div>
                    <ul class="mb-0 ps-4 small">
                        {{#each pesanError}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}

                {{#if pesanSukses}}
                <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm mb-4"
                    role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <ul class="mb-0 ps-3 small">
                        {{#each pesanSukses}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}

                <form method="POST" action="/auth/register" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="nama" class="form-label fw-semibold text-secondary small">Nama Lengkap</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-person"></i></span>
                            <input type="text" class="form-control bg-light border-start-0 ps-0" id="nama" name="nama"
                                placeholder="Masukkan nama" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="username" class="form-label fw-semibold text-secondary small">Username</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-at"></i></span>
                            <input type="text" class="form-control bg-light border-start-0 ps-0" id="username"
                                name="username" placeholder="Usermame anda" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label fw-semibold text-secondary small">Alamat Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control bg-light border-start-0 ps-0" id="email"
                                name="email" placeholder="akunAnda@lfpedia.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label fw-semibold text-secondary small">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i
                                    class="bi bi-lock"></i></span>
                            <input type="password" class="form-control bg-light border-start-0 ps-0" id="password"
                                name="password" placeholder="Minimal 6 karakter" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="foto_profil" class="form-label fw-semibold text-secondary small">Foto Profil
                            (Opsional)</label>
                        <input type="file" class="form-control bg-light" id="foto_profil" name="foto_profil"
                            accept="image/*">
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold shadow-sm mb-3">
                        Daftar Akun Baru
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="text-secondary small mb-0">Sudah punya akun? <a href="/auth/login"
                            class="text-decoration-none fw-semibold">Masuk di sini</a></p>
                </div>

            </div>
        </div>
    </div>
</div>