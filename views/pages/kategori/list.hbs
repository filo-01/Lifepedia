<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="d-md-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
            <div>
                <h2 class="fw-bold text-dark d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-grid-fill text-primary"></i>
                    Kategori Tutorial
                </h2>
                <p class="text-secondary small mb-0">
                    Daftar klasifikasi bidang lifehack yang tersedia di Lifepedia.
                </p>
            </div>

            {{#if session.email}}
            <div class="mt-2 mt-md-0">
                <a href="/kategori/create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                    <i class="bi bi-plus-circle-fill me-1"></i>
                    Tambah Kategori Baru
                </a>
            </div>
            {{/if}}
        </div>

        {{#if pesanSukses}}
        <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div>{{pesanSukses}}</div>
        </div>
        {{/if}}
        {{#if kategoriList}}
        <div class="row g-3">
            {{#each kategoriList}}
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3 bg-white">
                    <div class="card-body p-4 d-flex justify-content-between align-items-center">
                        <div class="pe-3">
                            <h5 class="fw-bold text-dark mb-2 d-flex align-items-center gap-2">
                                <span
                                    class="badge bg-primary-subtle text-primary rounded-pill px-2 py-1 border border-primary-subtle">
                                    <i class="bi bi-tag"></i>
                                </span>

                                {{this.nama_kategori}}

                            </h5>

                            <p class="text-secondary small mb-0">
                                {{this.deskripsi}}
                            </p>
                        </div>

                        {{#if ../session.email}}
                        <div class="d-flex align-items-center gap-2">
                            <a href="/kategori/edit/{{this.id}}"
                                class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                title="Edit Kategori">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <form method="POST" action="/kategori/delete/{{this.id}}" class="m-0"
                                onsubmit="return confirm('Yakin ingin menghapus kategori ini?')">
                                <button type="submit"
                                    class="btn btn-outline-danger btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                    title="Hapus Kategori">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </form>
                        </div>
                        {{/if}}
                    </div>
                </div>
            </div>

            {{/each}}
        </div>
        {{else}}
        <div class="text-center py-5 bg-white rounded-3 shadow-sm border border-light">
            <div
                class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle p-4 mb-3 fs-2">
                <i class="bi bi-folder-x"></i>
            </div>

            <h4 class="fw-bold text-dark mb-2">
                Belum Ada Kategori
            </h4>

            <p class="text-secondary mb-4">
                Belum ada kategori yang tersedia di Lifepedia.
            </p>

            {{#if session.email}}
            <a href="/kategori/create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                <i class="bi bi-plus-circle-fill me-1"></i>
                Tambah Kategori Pertama
            </a>
            {{/if}}
        </div>
        {{/if}}
    </div>
</div>