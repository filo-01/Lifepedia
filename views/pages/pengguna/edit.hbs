<div class="row justify-content-center my-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-gear display-4 text-primary"></i>
                    <h3 class="fw-bold mt-3">Edit Profil</h3>
                    <p class="text-muted">
                        Perbarui informasi akun Lifepedia Anda.
                    </p>
                </div>

                {{#if pesanError}}
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        {{#each pesanError}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}

                <form method="POST" action="/pengguna/edit">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Nama Lengkap
                        </label>
                        <input type="text" class="form-control" name="nama" value="{{pengguna.nama}}" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Username
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">@</span>
                            <input type="text" class="form-control" name="username" value="{{pengguna.username}}"
                                required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Email
                        </label>
                        <input type="email" class="form-control" value="{{pengguna.email}}" disabled>
                        <small class="text-muted">
                            Email tidak dapat diubah.
                        </small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Bio
                        </label>
                        <textarea class="form-control" name="bio" rows="4"
                            placeholder="Ceritakan sedikit tentang dirimu...">{{pengguna.bio}}</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="/pengguna/profil" class="btn btn-outline-secondary w-50">
                            Batal
                        </a>

                        <button type="submit" class="btn btn-primary w-50">
                            Simpan Perubahan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>