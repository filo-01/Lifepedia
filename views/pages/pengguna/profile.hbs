<div class="row justify-content-center g-4">
    <div class="col-12 col-lg-10">
        <div class="card border-0 shadow-sm rounded-3 bg-white mb-4 overflow-hidden">
            <div class="bg-primary bg-gradient" style="height: 120px;"></div>
            <div class="card-body p-4 position-relative">
                <div class="position-absolute" style="top: -60px; left: 24px;">
                    {{#if pengguna.foto_profil}}
                    <img src="/uploads/foto_profil/{{pengguna.foto_profil}}" alt="Foto Profil"
                        class="rounded-circle border border-4 border-white shadow-sm object-fit-cover" width="110"
                        height="110">
                    {{else}}
                    <div class="rounded-circle bg-light border border-4 border-white shadow-sm d-flex align-items-center justify-content-center text-secondary fs-1"
                        style="width:110px;height:110px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    {{/if}}
                </div>

                <div class="text-end mb-3">
                    <a href="/pengguna/edit" class="btn btn-outline-secondary rounded-pill btn-sm px-4 fw-semibold">
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit Profil
                    </a>
                </div>

                <div class="mt-4 pt-2">

                    <h3 class="fw-bold text-dark mb-0">
                        {{pengguna.nama}}
                    </h3>

                    <p class="text-primary fw-semibold small mb-2">
                        @{{pengguna.username}}
                    </p>

                    <div class="d-flex flex-wrap gap-3 text-muted small mb-3">

                        <span>
                            <i class="bi bi-envelope-fill me-1"></i>
                            {{pengguna.email}}
                        </span>

                        <span>
                            <i class="bi bi-calendar-check-fill me-1"></i>
                            Bergabung:
                            {{pengguna.dibuat_pada}}
                        </span>

                    </div>

                    {{#if pengguna.bio}}

                    <div class="bg-light p-3 rounded-3 border-start border-primary border-3">

                        <p class="mb-0 text-dark font-monospace small">
                            "{{pengguna.bio}}"
                        </p>

                    </div>

                    {{else}}

                    <div class="bg-light p-3 rounded-3 border-start border-secondary border-3">

                        <p class="mb-0 text-muted small">
                            Pengguna belum menambahkan bio.
                        </p>

                    </div>

                    {{/if}}

                </div>

            </div>

        </div>

        <div class="mb-3 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold text-dark d-flex align-items-center gap-2">
                    <i class="bi bi-grid-3x3-gap-fill text-secondary"></i>
                    Kontribusi Tutorial
                </h4>
                <p class="text-secondary small mb-0">
                    Daftar panduan dan lifehack yang pernah Anda bagikan ke komunitas Lifepedia.
                </p>
            </div>

            {{#if tutorialSaya}}
            <span class="badge bg-primary rounded-pill px-3 py-2">
                {{tutorialSaya.length}} Tutorial
            </span>
            {{/if}}
        </div>
        {{#if tutorialSaya}}
        <div class="row g-3">
            {{#each tutorialSaya}}
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3 bg-white">
                    <div class="card-body p-4 d-md-flex justify-content-between align-items-center">
                        <div class="pe-md-4 mb-3 mb-md-0">
                            <span
                                class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-1 small border border-secondary-subtle">
                                {{this.nama_kategori}}
                            </span>
                            <h5 class="fw-bold mt-2 mb-1">
                                <a href="/tutorial/detail/{{this.id}}"
                                    class="text-decoration-none text-dark link-primary">
                                    {{this.judul}}
                                </a>
                            </h5>
                            <p class="text-secondary small mb-0">
                                {{this.deskripsi}}
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/tutorial/edit/{{this.id}}" class="btn btn-sm btn-light border rounded-pill px-3">
                                <i class="bi bi-pencil"></i>
                                Edit
                            </a>
                            <form method="POST" action="/tutorial/delete/{{this.id}}" class="m-0"
                                onsubmit="return confirm('Yakin ingin menghapus tutorial ini?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="bi bi-trash3"></i>
                                    Hapus
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="text-center py-5 bg-white rounded-3 shadow-sm border border-light-subtle">
            <div
                class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle p-3 mb-3 fs-3">
                <i class="bi bi-journal-x"></i>
            </div>

            <h5 class="fw-bold text-dark mb-2">
                Belum Ada Tutorial
            </h5>

            <p class="text-secondary small mb-4">
                Anda belum pernah menulis tutorial.
            </p>

            <a href="/tutorial/create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle-fill me-1"></i>
                Tulis Tutorial Pertama
            </a>
        </div>
        {{/if}}
    </div>
</div>