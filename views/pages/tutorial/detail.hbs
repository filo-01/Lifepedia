<div class="row justify-content-center">
    <div class="col-lg-9">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/tutorial/list">Beranda</a>
                </li>
                <li class="breadcrumb-item">
                    {{tutorial.nama_kategori}}
                </li>
                <li class="breadcrumb-item active">
                    {{tutorial.judul}}
                </li>
            </ol>
        </nav>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <span class="badge bg-primary mb-3">
                    {{tutorial.nama_kategori}}
                </span>

                <h2 class="fw-bold">
                    {{tutorial.judul}}
                </h2>

                <p class="text-muted mb-4">
                    {{tutorial.deskripsi}}
                </p>

                <div
                    class="d-flex justify-content-between align-items-center flex-wrap border rounded p-3 bg-light mb-4">
                    <div class="d-flex align-items-center">
                        <img src="/uploads/foto_profil/{{tutorial.foto_profil}}" width="45" height="45"
                            class="rounded-circle border me-3">
                        <div>
                            <div class="fw-semibold">
                                {{tutorial.username}}
                            </div>

                            <small class="text-muted">
                                {{tutorial.dibuat_pada}}
                            </small>
                        </div>
                    </div>

                    <div class="text-end">
                        <div class="small text-muted">
                            <i class="bi bi-eye"></i>
                            {{tutorial.jumlah_dilihat}}
                            &nbsp;&nbsp;
                            <i class="bi bi-chat-left-text"></i>
                            {{tutorial.jumlah_komentar}}
                        </div>

                        {{#if session.email}}

                        <form method="POST" action="/bookmark/add/{{tutorial.id}}" class="mt-2">
                            <button class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-bookmark-heart"></i>
                                Bookmark
                            </button>
                        </form>
                        {{/if}}
                    </div>
                </div>
                <img src="/uploads/tutorial/{{tutorial.isi}}" class="img-fluid rounded border shadow-sm w-100">
            </div>
        </div>

        {{#if session.email}}
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">
                    <i class="bi bi-chat-left-text"></i>
                    Tulis Komentar
                </h5>

                <form method="POST" action="/komentar/create/{{tutorial.id}}">
                    <textarea class="form-control mb-3" rows="4" name="isi" placeholder="Bagikan pendapatmu..."
                        required></textarea>
                    <button class="btn btn-primary">
                        Kirim Komentar
                    </button>
                </form>
            </div>
        </div>

        {{/if}}
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="mb-4">
                    <i class="bi bi-chat-dots"></i>
                    Komentar ({{tutorial.jumlah_komentar}})
                </h5>

                {{#if komentarList}}
                {{#each komentarList}}
                <div class="border-bottom pb-3 mb-3">
                    <div class="d-flex justify-content-between">
                        <div class="d-flex">
                            <img src="/uploads/foto_profil/{{this.foto_profil}}" width="40" height="40"
                                class="rounded-circle me-3 border">
                            <div>
                                <div class="fw-semibold">
                                    {{this.username}}
                                </div>
                                <small class="text-muted">
                                    {{this.dibuat_pada}}
                                </small>
                            </div>
                        </div>

                        {{#if (eq ../session.penggunaId this.pengguna_id)}}
                        <form method="POST" action="/komentar/delete/{{this.id}}">
                            <button class="btn btn-sm btn-outline-danger">
                                Hapus
                            </button>
                        </form>
                        {{/if}}
                    </div>

                    <p class="mt-3 mb-0">
                        {{this.isi}}
                    </p>
                </div>

                {{/each}}
                {{else}}
                <div class="text-center py-5">
                    <i class="bi bi-chat-square-text display-4 text-secondary"></i>
                    <h5 class="mt-3">
                        Belum Ada Komentar
                    </h5>

                    <p class="text-muted">
                        Jadilah orang pertama yang memberikan komentar
                    </p>

                </div>
                {{/if}}
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="/tutorial/list" class="btn btn-outline-secondary">
                ← Kembali
            </a>
        </div>
    </div>
</div>