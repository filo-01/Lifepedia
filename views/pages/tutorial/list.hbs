<div class="row justify-content-center">
    <div class="col-12 col-lg-11">
        <div class="card border-0 shadow-sm rounded-3 bg-white p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <h2 class="fw-bold text-dark mb-1 d-flex align-items-center gap-2">
                        <i class="bi bi-compass-fill text-primary"></i> Jelajah Lifehack
                    </h2>
                    <p class="text-secondary small mb-0">Temukan solusi cepat dan panduan infografis kreatif dari
                        komunitas.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="/tutorial/create" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> Tulis Tutorial Baru
                    </a>
                </div>
            </div>

            <hr class="my-3 opacity-25">
            <form method="GET" action="/tutorial/list" class="row g-2 m-0">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i
                                class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control bg-light border-start-0 ps-0"
                            placeholder="Cari judul tutorial atau kata kunci...">
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-outline-primary w-100 rounded-pill fw-semibold">
                        <i class="bi bi-sliders me-1"></i> Terapkan Filter
                    </button>
                </div>
            </form>
        </div>

        {{#if pesanSukses}}
        <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <div>{{pesanSukses}}</div>
        </div>
        {{/if}}

        {{#if tutorialList}}
        <div class="row g-4">
            {{#each tutorialList}}
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 bg-white overflow-hidden d-flex flex-column">

                    <div class="bg-light d-flex align-items-center justify-content-center overflow-hidden border-bottom position-relative"
                        style="height: 180px;">
                        <img src="/uploads/tutorial/{{this.isi}}" alt="Preview Infografis"
                            class="w-100 h-100 object-fit-cover">
                        <span
                            class="badge bg-dark bg-opacity-75 rounded-pill position-absolute top-0 end-0 m-3 px-3 py-2 small border border-secondary border-opacity-25">
                            {{this.nama_kategori}}
                        </span>
                    </div>

                    <div class="card-body p-4 d-flex flex-column flex-grow-1">
                        <h5 class="card-title fw-bold mb-2">
                            <a href="/tutorial/detail/{{this.id}}" class="text-decoration-none text-dark link-primary">
                                {{this.judul}}
                            </a>
                        </h5>
                        <p class="card-text text-secondary small flex-grow-1 text-truncate-2 mb-3">
                            {{this.deskripsi}}
                        </p>

                        <hr class="my-3 opacity-25">

                        <div class="d-flex align-items-center justify-content-between mt-auto">
                            <div class="d-flex align-items-center gap-2">
                                <img src="/uploads/foto_profil/{{this.foto_profil}}" alt="Creator"
                                    class="rounded-circle border" width="32" height="32">
                                <span class="fw-semibold text-dark small">@{{this.username}}</span>
                            </div>
                            <a href="/tutorial/detail/{{this.id}}"
                                class="btn btn-sm btn-link text-decoration-none fw-semibold p-0">
                                Lihat Detail <i class="bi bi-arrow-right small"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="text-center py-5 bg-white rounded-3 shadow-sm border border-light-subtle">
            <div
                class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle p-4 mb-3 fs-1">
                <i class="bi bi-journal-x"></i>
            </div>
            <h4 class="fw-bold text-dark mb-1">Tutorial Tidak Ditemukan</h4>
            <p class="text-secondary small mb-0">Belum ada kiriman lifehack atau kata kunci pencarianmu tidak cocok.</p>
        </div>
        {{/if}}

    </div>
</div>